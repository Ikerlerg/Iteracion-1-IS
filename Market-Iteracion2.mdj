											"$ref": "AAAAAAGcuNuFAy5OkFI="
										},
										"navigable": "navigable"
									}
								}
							],
							"documentation": "#FE: Aceptar Oferta:\n1. El SISTEMA tiene que mostrar una lista con todas las ofertas disponibles.\n2. El BUYER tiene que seleccionar una oferta de venta.\n3. El BUYER introducira el precio ajustado a la oferta.\n4. El SISTEMA guardara la oferta comprada para añadirla a la lista de ofertas aceptadas.\n\n##FE: Alternativo:\n* Si el precio es diferente al exigido por la oferta, da FALLO.\n"
						},
						{
							"_type": "UMLUseCase",
							"_id": "AAAAAAGcuNyAJTGX3+k=",
							"_parent": {
								"$ref": "AAAAAAGcuNq1ci0dXsE="
							},
							"name": "Visualizar Oferta Aceptadas",
							"ownedElements": [
								{
									"_type": "UMLExtend",
									"_id": "AAAAAAGdgsU9fyTSWJw=",
									"_parent": {
										"$ref": "AAAAAAGcuNyAJTGX3+k="
									},
									"source": {
										"$ref": "AAAAAAGcuNyAJTGX3+k="
									},
									"target": {
										"$ref": "AAAAAAGcuNv3iDEIyTE="
									}
								}
							],
							"documentation": "#FE: Aceptar Oferta:\n1. El SISTEMA tiene que mostrar una lista con todas las ofertas aceptadas subidas a la base de datos.\n2. El USER puede revisar y ver todos los datos de las ofertas.\n4. El SISTEMA guardara la oferta comprada para añadirla a la lista de ofertas aceptadas.\n\n##FE: Alternativo:\n\n"
						},
						{
							"_type": "UMLUseCase",
							"_id": "AAAAAAGcumeSfRMMCGA=",
							"_parent": {
								"$ref": "AAAAAAGcuNq1ci0dXsE="
							},
							"name": "Hacer Oferta",
							"ownedElements": [
