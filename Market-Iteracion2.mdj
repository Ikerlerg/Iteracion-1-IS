								"$ref": "AAAAAAGcuNq1ci0dXsE="
							},
							"name": "Cerrar Sesion",
							"documentation": "#FE: Cerrar Sesion:\n1. El SISTEMA dejara de tomar en cuenta el usuario iniciado y dejara la sesion vacia.\n\n##FE: Alternativo:\n* Si se intenta hacer cuando no se ha iniciado sesion con una cuenta, no ocurrira nada."
						},
						{
							"_type": "UMLUseCase",
							"_id": "AAAAAAGdgWRsabsXZLw=",
							"_parent": {
								"$ref": "AAAAAAGcuNq1ci0dXsE="
							},
							"name": "Carrito de la compra",
							"ownedElements": [
								{
									"_type": "UMLInclude",
									"_id": "AAAAAAGdgshCZZbejyE=",
									"_parent": {
