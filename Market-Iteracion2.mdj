							},
							"name": "Aceptar Compra",
							"ownedElements": [
								{
									"_type": "UMLAssociation",
									"_id": "AAAAAAGdgr3bNJynXOc=",
									"_parent": {
										"$ref": "AAAAAAGcuNv3iDEIyTE="
									},
									"end1": {
